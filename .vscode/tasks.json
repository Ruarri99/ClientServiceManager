{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe build active file",
            "command": "C:\\msys64\\ucrt64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-municode",
                "-g",
                "${fileDirname}\\main.cpp",
                "${fileDirname}\\Window.cpp",
                "-o",
